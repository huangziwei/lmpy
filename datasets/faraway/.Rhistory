llMixedMV = function(y, X, Z, theta){
tau = exp(theta[1])
sigma = exp(theta[2])
n = length(y)
# evaluate covariance matrix for y
e = tcrossprod(Z)*tau^2 + diag(n)*sigma^2
b = coef(lm.fit(X, y))
mu = X %*% b
ll = -mvtnorm::dmvnorm(y, mu, e, log=T)
}
