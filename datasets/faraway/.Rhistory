L <- getME(m, "L")
Lambda <- getME(m, "Lambda")
Zt <- getME(m, "Zt")
Ut <- crossprod(Lambda, Zt)
X <- getME(m, "X")
Rzx <- solve(L, solve(L, crossprod(Lambda, Zt %*% X), sys='P'), sys='L')
par(mfrow=c(1,3))
plot(as.matrix(Lambda), col=topo.colors, breaks=50, digits=2)
plot(as.matrix(Zt %*% t(Zt)), col=topo.colors, breaks=50, digits=2)
plot(as.matrix(expand(L)$L), col=topo.colors, breaks=50, digits=2)
